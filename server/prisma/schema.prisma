generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id          String    @id @default(uuid())
  name        String
  clientName  String
  sowRaw      String
  sowSummary  Json
  messages    Message[]
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model Message {
  id             String   @id @default(uuid())
  clientMessage  String
  verdict        String
  explanation    String
  suggestedReply String
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id])
  createdAt      DateTime @default(now())
}